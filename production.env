# Production Environment Configuration
# ⚠️ SECURITY WARNING: This file contains sensitive credentials
# DO NOT commit this file to version control
# Generate secure values using: ./scripts/security/generate-secrets.sh

NODE_ENV=production
PORT=5000
FRONTEND_PORT=3001

# Database Configuration
# ⚠️ REQUIRED: Set secure database credentials
# For new server deployment, update DB_HOST to: 172.27.0.10
DB_HOST=172.27.0.10
DB_PORT=5432
DB_NAME=inventory_db
DB_USER=inventory_user
# ⚠️ REQUIRED: Generate secure password using generate-secrets.sh
DB_PASS=CHANGE_THIS_TO_SECURE_PASSWORD

# Security Configuration
# ⚠️ REQUIRED: Generate a secure JWT secret (min 64 characters)
# Run: ./scripts/security/generate-secrets.sh
SECRETKEY=CHANGE_THIS_TO_SECURE_JWT_SECRET_MIN_64_CHARACTERS
JWT_SECRET=CHANGE_THIS_TO_SECURE_JWT_SECRET_MIN_64_CHARACTERS
JWT_EXPIRE=30d
BCRYPT_ROUNDS=12

# CORS Configuration
# ⚠️ REQUIRED: Update with production domain(s)
CORS_ORIGIN=https://your-domain.com
CORS_CREDENTIALS=true

# Session Configuration
SESSION_SECRET=CHANGE_THIS_TO_SECURE_SESSION_SECRET
SESSION_MAX_AGE=86400000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Email Configuration (if needed)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-email-password

# Frontend URL (for CORS and redirects)
FRONTEND_URL=https://your-domain.com
