{
  "extends": [
    "react-app",
    "react-app/jest"
  ],
  "rules": {
    "no-unused-vars": "off",
    "react-hooks/exhaustive-deps": "off",
    "jsx-a11y/anchor-is-valid": "off",
    "no-script-url": "off",
    "@typescript-eslint/no-unused-vars": "off"
  },
  "ignorePatterns": [
    "build/**",
    "node_modules/**",
    "*.config.js"
  ]
}

