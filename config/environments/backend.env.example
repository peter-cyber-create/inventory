# Ministry of Health Uganda Inventory Management System
# Environment Configuration
# ⚠️ SECURITY WARNING: This is a template file
# Copy this file to backend.env and fill in secure values
# Generate secure secrets using: ./scripts/security/generate-secrets.sh
# DO NOT commit backend.env to version control

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_db
DB_USER=inventory_user
# ⚠️ REQUIRED: Set secure database password
DB_PASS=your_secure_password_here

# JWT Configuration
# ⚠️ REQUIRED: Generate secure JWT secret (min 64 characters)
# Note: The application uses SECRETKEY, but this file uses JWT_SECRET for clarity
# Run: ./scripts/security/generate-secrets.sh
SECRETKEY=your_super_secure_jwt_secret_key_here_change_in_production
JWT_SECRET=your_super_secure_jwt_secret_key_here_change_in_production
JWT_EXPIRE=30d

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# File Upload Configuration
MAX_FILE_SIZE=10000000
UPLOAD_PATH=./uploads

# CORS Configuration
FRONTEND_URL=http://localhost:3000
