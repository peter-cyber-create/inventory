# Production Environment Configuration
# ⚠️ SECURITY WARNING: This is a template file
# Copy this file to production.env and fill in secure values
# Generate secure secrets using: ./scripts/security/generate-secrets.sh
# DO NOT commit production.env to version control

# Database Configuration
# For new server deployment, update DB_HOST to: 172.27.0.10
DB_HOST=172.27.0.10
DB_PORT=5432
DB_NAME=inventory_db
DB_USER=inventory_user
# ⚠️ REQUIRED: Generate secure password using generate-secrets.sh
DB_PASS=CHANGE_THIS_TO_SECURE_PASSWORD

# Server Configuration
NODE_ENV=production
PORT=5000
FRONTEND_PORT=3000

# Security
# ⚠️ REQUIRED: Generate secure JWT secret (min 64 characters)
# Run: ./scripts/security/generate-secrets.sh
SECRETKEY=CHANGE_THIS_TO_SECURE_JWT_SECRET_MIN_64_CHARACTERS
BCRYPT_ROUNDS=12

# CORS Configuration
CORS_ORIGIN=https://your-domain.com
CORS_CREDENTIALS=true

# Session Configuration
SESSION_SECRET=your-session-secret-key
SESSION_MAX_AGE=86400000

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Email Configuration (if needed)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-email-password

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
